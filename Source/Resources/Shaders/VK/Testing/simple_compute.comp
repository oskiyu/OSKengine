#version 460

layout (local_size_x = 8, local_size_y = 8) in;

layout (set = 0, binding = 0) uniform bufferContent {
    int xd;
};

layout (set = 1, binding = 0, rgba8) uniform image2D finalImage;

void main() {
    const ivec2 iuv = ivec2(gl_GlobalInvocationID.xy);
    const vec2   uv =  vec2(gl_GlobalInvocationID.xy) / vec2(256);
    imageStore(finalImage, iuv, vec4(uv.xy, 0, 1.0));
}
